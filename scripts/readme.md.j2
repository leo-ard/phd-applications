{%- macro deadline(uni) -%}
{%- if uni.deadline is sequence_not_string -%}
{%- if uni.deadline_url %}[Application deadline]({{ uni.deadline_url }})
{%- else %}Application deadline
{%- endif -%}:

{% for item in uni.deadline -%}
- {% if item is mapping -%}
{{ item.text }}{{ " — see [%s](%s)" | format(item.url | domain, item.url) if item.url else "" }}
{%- else -%}
{{ item }}
{%- endif %}
{% endfor -%}
{%- else -%}
{%- if uni.deadline_url %}[Application deadline]({{ uni.deadline_url }})
{%- else %}Application deadline
{%- endif -%}: {{ uni.deadline | default('❔') }}
{%- endif -%}
{%- endmacro -%}

{%- macro professor(prof) -%}
{%- set links = [] -%}
{%- if prof.homepage %}{% set _ = links.append("[Homepage](" ~ prof.homepage ~ ")") %}{% endif -%}
{%- if prof.scholar %}{% set _ = links.append("[Scholar](" ~ prof.scholar ~ ")") %}{% endif -%}
{%- if prof.orcid %}{% set _ = links.append("[ORCID](" ~ prof.orcid ~ ")") %}{% endif -%}
{%- if prof.dblp %}{% set _ = links.append("[DBLP](" ~ prof.dblp ~ ")") %}{% endif -%}
{% if links -%}
**{{ prof.name }}** — {{ links | join(' · ') }}
{%- else -%}
**{{ prof.name }}**
{%- endif %}

- Research: {{ prof.research | default('❔') }}

- Taking students: {% if prof.taking_students is true %}✅{% elif prof.taking_students is false %}❌{% else %}❔{% endif %}
{%- endmacro %}
